    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 24 },
