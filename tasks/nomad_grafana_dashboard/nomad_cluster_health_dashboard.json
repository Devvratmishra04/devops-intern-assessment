{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🖥️ Server & Client Node Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "NO LEADER" }, "1": { "color": "green", "text": "HEALTHY (LEADER)" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 2 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(nomad_nomad_raft_state == 1)",
          "legendFormat": "Raft Leader",
          "refId": "A"
        }
      ],
      "title": "Raft Leader Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 2 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(nomad_nomad_memberlist_health_score)",
          "legendFormat": "Health Score",
          "refId": "A"
        }
      ],
      "title": "Memberlist Health Score",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 2 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nomad_nomad_raft_leader_last_contact",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ],
      "title": "Raft Leader Contact Latency",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 2 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(nomad_client_allocated_cpu)",
          "legendFormat": "Active Clients",
          "refId": "A"
        }
      ],
      "title": "Nomad Active Client Nodes",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 6 },
      "id": 200,
      "title": "📦 Job Allocations & Failures",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "showPoints": "never" }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nomad_nomad_job_status",
          "legendFormat": "Job {{ job }} ({{ status }})",
          "refId": "A"
        }
      ],
      "title": "Job Status Breakdown",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nomad_client_allocations_running) by (instance)",
          "legendFormat": "Running Allocs ({{ instance }})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nomad_client_allocations_failed) by (instance)",
          "legendFormat": "Failed Allocs ({{ instance }})",
          "refId": "B"
        }
      ],
      "title": "Running vs Failed Allocations",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 15 },
      "id": 300,
      "title": "⚡ Resource Utilization (CPU & Memory)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30 },
          "unit": "mhz"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nomad_client_allocated_cpu)",
          "legendFormat": "Allocated CPU (MHz)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nomad_client_unallocated_cpu)",
          "legendFormat": "Unallocated CPU (MHz)",
          "refId": "B"
        }
      ],
      "title": "Cluster CPU Allocation (Allocated vs Available)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nomad_client_allocated_memory)",
          "legendFormat": "Allocated RAM",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nomad_client_unallocated_memory)",
          "legendFormat": "Unallocated RAM",
          "refId": "B"
        }
      ],
      "title": "Cluster Memory Allocation (Allocated vs Available)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 24 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, nomad_client_allocs_cpu_total_percent)",
          "legendFormat": "{{ job }} - {{ task }} ({{ alloc_id }})",
          "refId": "A"
        }
      ],
      "title": "Top 10 Allocation CPU Usage (%)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 24 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, nomad_client_allocs_memory_usage)",
          "legendFormat": "{{ job }} - {{ task }} ({{ alloc_id }})",
          "refId": "A"
        }
      ],
      "title": "Top 10 Allocation Memory Usage",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 31 },
      "id": 400,
      "title": "🚀 Deployment Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 33 },
      "id": 11,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nomad_nomad_deployments_active) || vector(0)",
          "legendFormat": "Active Deployments",
          "refId": "A"
        }
      ],
      "title": "Active Deployments",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15 }
        }
      },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 33 },
      "id": 12,
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nomad_nomad_deployments_successful)",
          "legendFormat": "Successful Deployments",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nomad_nomad_deployments_failed)",
          "legendFormat": "Failed Deployments",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(nomad_nomad_deployments_cancelled)",
          "legendFormat": "Cancelled Deployments",
          "refId": "C"
        }
      ],
      "title": "Deployment Outcomes Over Time",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["nomad", "cluster-health", "hashicorp", "prometheus"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]
  },
  "timezone": "browser",
  "title": "Nomad Cluster Health",
  "uid": "nomad-cluster-health",
  "version": 1
}
